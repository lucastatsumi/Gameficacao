# Copie para .env e preencha com os valores do seu projeto Supabase
# (Dashboard > Project Settings > API). NUNCA commitar o .env.

PORT=3001

# URL do projeto Supabase
SUPABASE_URL=https://xxxxxxxx.supabase.co

# Chave service_role: usada SOMENTE no backend (ignora RLS)
SUPABASE_SERVICE_ROLE_KEY=

# Chave anon/publishable: usada para validar JWT dos usuários
SUPABASE_ANON_KEY=

# Origem permitida no CORS (URL do frontend)
FRONTEND_URL=http://localhost:5173
